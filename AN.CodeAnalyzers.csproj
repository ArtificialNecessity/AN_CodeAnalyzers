<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <LangVersion>12.0</LangVersion>
    <Nullable>enable</Nullable>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
    <IsRoslynComponent>true</IsRoslynComponent>
    <DefaultItemExcludes>$(DefaultItemExcludes);**/Tests/**;StableABIVerification/**;VerifyUserConfigGitignore/**;CoreTools/**</DefaultItemExcludes>

    <!-- Package properties -->
    <PackageId>ArtificialNecessity.CodeAnalyzers</PackageId>
    <VersionPrefix>0.0.0</VersionPrefix>
    <Authors>David Jeske</Authors>
    <Description>C# code analyzers for preventing silent binary compatibility breaks in C# projects (guardrails for humans and AI). Includes ExplicitEnums (AN0001), PublicConstAnalyzer (AN0002), StableABI snapshot verification, VerifyUserConfigGitignore, and JsonPeek MSBuild tasks.</Description>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/ArtificialNecessity/AN_CodeAnalyzers</PackageProjectUrl>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <RepositoryUrl>https://github.com/ArtificialNecessity/AN_CodeAnalyzers</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>roslyn;analyzer;code-analysis;binary-compatibility;enum;const;abi;stable-api</PackageTags>
    <DevelopmentDependency>true</DevelopmentDependency>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <SuppressDependenciesWhenPacking>true</SuppressDependenciesWhenPacking>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>

    <!-- Local NuGet feed: set LOCAL_NUGET_REPO env var to enable auto-deploy -->
    <LocalNuGetFeedPath>$(LOCAL_NUGET_REPO)</LocalNuGetFeedPath>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.8.0" PrivateAssets="all" />
    <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" Version="3.3.4" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <!-- Pack README.md for NuGet.org package page -->
    <None Include="README.md" Pack="true" PackagePath="\" />
    <!-- Pack the analyzer DLL in the analyzers/dotnet/cs directory -->
    <None Include="$(OutputPath)\$(AssemblyName).dll" Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />
    <!-- Pack the .targets file so consuming projects get MSBuild targets automatically -->
    <None Include="build\ArtificialNecessity.CodeAnalyzers.targets" Pack="true" PackagePath="build" Visible="false" />
    <!-- Pack the StableABI MSBuild task DLL in the tasks/ directory -->
    <None Include="StableABIVerification\bin\$(Configuration)\netstandard2.0\StableABIVerification.dll" Pack="true" PackagePath="tasks/netstandard2.0" Visible="false" />
    <None Include="StableABIVerification\bin\$(Configuration)\netstandard2.0\System.Reflection.Metadata.dll" Pack="true" PackagePath="tasks/netstandard2.0" Visible="false" Condition="Exists('StableABIVerification\bin\$(Configuration)\netstandard2.0\System.Reflection.Metadata.dll')" />
    <!-- Pack the VerifyUserConfigGitignore MSBuild task DLL in the tasks/ directory -->
    <None Include="VerifyUserConfigGitignore\bin\$(Configuration)\netstandard2.0\VerifyUserConfigGitignore.dll" Pack="true" PackagePath="tasks/netstandard2.0" Visible="false" />
    <None Include="VerifyUserConfigGitignore\bin\$(Configuration)\netstandard2.0\MAB.DotIgnore.dll" Pack="true" PackagePath="tasks/netstandard2.0" Visible="false" Condition="Exists('VerifyUserConfigGitignore\bin\$(Configuration)\netstandard2.0\MAB.DotIgnore.dll')" />
    <!-- Pack the JsonPeek MSBuild task DLL in the tasks/ directory -->
    <None Include="CoreTools\bin\$(Configuration)\netstandard2.0\JsonPeekTask.dll" Pack="true" PackagePath="tasks/netstandard2.0" Visible="false" />
    <None Include="CoreTools\bin\$(Configuration)\netstandard2.0\Hjson.dll" Pack="true" PackagePath="tasks/netstandard2.0" Visible="false" Condition="Exists('CoreTools\bin\$(Configuration)\netstandard2.0\Hjson.dll')" />
  </ItemGroup>

  <!-- ════════════════════════════════════════════════════════════════
       Git-height versioning: {major}.{minor}.{buildNumberOffset}-{GitHeight}.{BuildNum}.g{GitHash}
       Example: 0.1.2-14.3.gfba06ee
       Reads base version + buildNumberOffset from version.json at repo root
       using the locally-built JsonPeek task (self-hosted — we ARE the package).
       BuildNum auto-increments on every build via buildnum.txt.
       For a clean release: dotnet build /p:Version=0.1.2
       ════════════════════════════════════════════════════════════════ -->

  <!-- Register the locally-built JsonPeek task for reading version.json
       (we can't use the NuGet package version because we ARE the package) -->
  <UsingTask
    TaskName="AN.CodeAnalyzers.JsonPeek"
    AssemblyFile="$(MSBuildProjectDirectory)\CoreTools\bin\$(Configuration)\netstandard2.0\JsonPeekTask.dll"
    Condition="Exists('$(MSBuildProjectDirectory)\CoreTools\bin\$(Configuration)\netstandard2.0\JsonPeekTask.dll')" />

  <!-- Increment buildnum.txt before computing the version -->
  <Target Name="IncrementBuildNumber" BeforeTargets="ComputeGitVersion">
    <ReadLinesFromFile File="$(MSBuildProjectDirectory)\buildnum.txt" Condition="Exists('$(MSBuildProjectDirectory)\buildnum.txt')">
      <Output TaskParameter="Lines" PropertyName="PreviousBuildNumber" />
    </ReadLinesFromFile>
    <PropertyGroup>
      <PreviousBuildNumber Condition="'$(PreviousBuildNumber)' == ''">0</PreviousBuildNumber>
      <LocalBuildNumber>$([MSBuild]::Add($(PreviousBuildNumber), 1))</LocalBuildNumber>
    </PropertyGroup>
    <WriteLinesToFile File="$(MSBuildProjectDirectory)\buildnum.txt" Lines="$(LocalBuildNumber)" Overwrite="true" />
  </Target>

  <Target Name="ComputeGitVersion" BeforeTargets="GenerateNuspecDependencies;GetPackageVersionInfo;Pack;GenerateAssemblyInfo">

    <!-- Read base version and buildNumberOffset from version.json via locally-built JsonPeek -->
    <JsonPeek File="$(MSBuildProjectDirectory)\version.json" KeyPath="version"
              Condition="Exists('$(MSBuildProjectDirectory)\version.json') AND Exists('$(MSBuildProjectDirectory)\CoreTools\bin\$(Configuration)\netstandard2.0\JsonPeekTask.dll')">
      <Output TaskParameter="Value" PropertyName="_BaseVersionFromJson" />
    </JsonPeek>
    <JsonPeek File="$(MSBuildProjectDirectory)\version.json" KeyPath="buildNumberOffset"
              Condition="Exists('$(MSBuildProjectDirectory)\version.json') AND Exists('$(MSBuildProjectDirectory)\CoreTools\bin\$(Configuration)\netstandard2.0\JsonPeekTask.dll')">
      <Output TaskParameter="Value" PropertyName="_BuildNumberOffsetFromJson" />
    </JsonPeek>

    <!-- Compose VersionPrefix: {major}.{minor}.{buildNumberOffset} -->
    <PropertyGroup Condition="'$(_BaseVersionFromJson)' != ''">
      <_BuildNumberOffsetFromJson Condition="'$(_BuildNumberOffsetFromJson)' == ''">0</_BuildNumberOffsetFromJson>
      <VersionPrefix>$(_BaseVersionFromJson).$(_BuildNumberOffsetFromJson)</VersionPrefix>
    </PropertyGroup>

    <Exec Command="git rev-list --count HEAD" ConsoleToMSBuild="true" StandardOutputImportance="low">
      <Output TaskParameter="ConsoleOutput" PropertyName="GitCommitHeight" />
    </Exec>
    <Exec Command="git rev-parse --short HEAD" ConsoleToMSBuild="true" StandardOutputImportance="low">
      <Output TaskParameter="ConsoleOutput" PropertyName="GitShortHash" />
    </Exec>
    <PropertyGroup>
      <Version>$(VersionPrefix)-$(GitCommitHeight).$(LocalBuildNumber).g$(GitShortHash)</Version>
      <PackageVersion>$(Version)</PackageVersion>
      <InformationalVersion>$(Version)</InformationalVersion>
    </PropertyGroup>
    <Message Importance="High" Text="AN.CodeAnalyzers version: $(Version)" />
  </Target>

  <!-- Deploy .nupkg to local NuGet feed after pack -->
  <Target Name="DeployToLocalNuGet" AfterTargets="Pack" Condition="'$(LocalNuGetFeedPath)' != ''">
    <MakeDir Directories="$(LocalNuGetFeedPath)" Condition="!Exists('$(LocalNuGetFeedPath)')" />
    <Copy SourceFiles="$(PackageOutputPath)$(PackageId).$(PackageVersion).nupkg"
          DestinationFolder="$(LocalNuGetFeedPath)"
          OverwriteReadOnlyFiles="true" />
    <Message Importance="High" Text="AN.CodeAnalyzers: Deployed $(PackageId).$(PackageVersion).nupkg to $(LocalNuGetFeedPath)" />
  </Target>

</Project>
