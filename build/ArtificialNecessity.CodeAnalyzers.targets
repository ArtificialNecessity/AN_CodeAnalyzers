<Project>

  <!-- Make MSBuild properties visible to Roslyn analyzers at compile time -->
  <ItemGroup>
    <!-- ExplicitEnums (AN0001) -->
    <CompilerVisibleProperty Include="EnforceExplicitEnumValues" />
    <!-- RequireTypedPointersNotIntPtr (AN0100) -->
    <CompilerVisibleProperty Include="RequireTypedPointersNotIntPtr" />
    <!-- EnforceNamingConventions (AN0200) -->
    <CompilerVisibleProperty Include="EnforceNamingConventions" />
  </ItemGroup>

  <!-- ════════════════════════════════════════════════════════════════
       Task DLL location:
         NuGet consumption (default): {package}/tasks/netstandard2.0/
         Source-tree dev: set ANCodeAnalyzersTaskDir before importing this file
       ════════════════════════════════════════════════════════════════ -->
  <PropertyGroup>
    <ANCodeAnalyzersTaskDir Condition="'$(ANCodeAnalyzersTaskDir)' == ''">$(MSBuildThisFileDirectory)..\tasks\netstandard2.0\</ANCodeAnalyzersTaskDir>
  </PropertyGroup>

  <!-- ════════════════════════════════════════════════════════════════
       StableABI Snapshot Verification (MSBuild Task - Out-of-Process)

       TaskHostFactory runs the task in a separate process, avoiding DLL locking.
       This allows rebuilding StableABIVerification without shutting down MSBuild.

       Normal build:    dotnet build                        → verifies snapshot
       Update snapshot: dotnet build /p:UpdateStableABI=true → generates snapshot
       ════════════════════════════════════════════════════════════════ -->

  <!-- TaskHostFactory runs the task in a separate MSBuild.exe process.
       This prevents DLL locking — you can rebuild StableABIVerification.dll
       and it will be picked up on the next build without needing to shut down
       the MSBuild server. Without TaskHostFactory, MSBuild loads the DLL into
       its own process and locks it until shutdown. -->
  <UsingTask
    TaskName="AN.CodeAnalyzers.StableABIVerification.StableABIVerifyTask"
    AssemblyFile="$(ANCodeAnalyzersTaskDir)StableABIVerification.dll"
    TaskFactory="TaskHostFactory" />

  <!-- Snapshot filename: $(AssemblyName).stableapi next to the .csproj -->
  <PropertyGroup>
    <StableABISnapshotPath Condition="'$(StableABISnapshotPath)' == ''">$(MSBuildProjectDirectory)\$(AssemblyName).stableapi</StableABISnapshotPath>
  </PropertyGroup>

  <!-- Verify snapshot after every build (skip when UpdateStableABI=true)
       Only runs when ANDevMode environment variable is set (for development of this analyzer package itself) -->
  <Target Name="VerifyStableABI"
          AfterTargets="Build"
          Condition="'$(StableABISnapshotScope)' != '' AND '$(StableABISnapshotScope)' != 'none' AND '$(UpdateStableABI)' != 'true' AND '$(ANDevMode)' != ''">
    <StableABIVerifyTask
      AssemblyPath="$(TargetPath)"
      SnapshotPath="$(StableABISnapshotPath)"
      Scope="$(StableABISnapshotScope)"
      GenerateMode="false" />
  </Target>

  <!-- Generate/update snapshot when UpdateStableABI=true -->
  <Target Name="GenerateStableABISnapshot"
          AfterTargets="Build"
          Condition="'$(UpdateStableABI)' == 'true'">
    <PropertyGroup>
      <StableABISnapshotScope Condition="'$(StableABISnapshotScope)' == '' OR '$(StableABISnapshotScope)' == 'none'">public</StableABISnapshotScope>
    </PropertyGroup>
    <StableABIVerifyTask
      AssemblyPath="$(TargetPath)"
      SnapshotPath="$(StableABISnapshotPath)"
      Scope="$(StableABISnapshotScope)"
      GenerateMode="true" />
  </Target>

  <!-- ════════════════════════════════════════════════════════════════
       VerifyUserConfigGitignore (MSBuild Task - Out-of-Process)
       
       Verifies that user-config files are properly gitignored to prevent
       accidental commits of per-developer configuration.
       
       Enable: <VerifyUserConfigGitignore>true</VerifyUserConfigGitignore>
       Severity: <VerifyUserConfigGitignoreSeverity>warning</VerifyUserConfigGitignoreSeverity>
       ════════════════════════════════════════════════════════════════ -->

  <UsingTask
    TaskName="AN.CodeAnalyzers.VerifyUserConfigGitignore.VerifyUserConfigGitignoreTask"
    AssemblyFile="$(ANCodeAnalyzersTaskDir)VerifyUserConfigGitignore.dll"
    TaskFactory="TaskHostFactory" />

  <!-- Default severity to error if not specified -->
  <PropertyGroup>
    <VerifyUserConfigGitignoreSeverity Condition="'$(VerifyUserConfigGitignoreSeverity)' == ''">error</VerifyUserConfigGitignoreSeverity>
  </PropertyGroup>

  <!-- Run verification before build when enabled -->
  <Target Name="VerifyUserConfigGitignore"
          BeforeTargets="Build"
          Condition="'$(VerifyUserConfigGitignore)' == 'true'">
    <VerifyUserConfigGitignoreTask
      ProjectDirectory="$(MSBuildProjectDirectory)"
      Severity="$(VerifyUserConfigGitignoreSeverity)" />
  </Target>

  <!-- ════════════════════════════════════════════════════════════════
       JsonPeek (MSBuild Task - Out-of-Process)
       
       Reads a value from a JSON/JSONC/HJSON file by dot-separated key path.
       Extension-agnostic — parses content regardless of file extension.
       
       Usage:
         <JsonPeek File="config.json" KeyPath="version">
           <Output TaskParameter="Value" PropertyName="ConfigVersion" />
         </JsonPeek>
       ════════════════════════════════════════════════════════════════ -->

  <UsingTask
    TaskName="AN.CodeAnalyzers.JsonPeek"
    AssemblyFile="$(ANCodeAnalyzersTaskDir)JsonPeekTask.dll"
    TaskFactory="TaskHostFactory" />

</Project>